# ─── Google Maps Platform ─────────────────────────────────────────────────────
# Required for destination autocomplete in the campaign wizard (StepTargeting).
# Without this key the destination field falls back to a plain text input.
#
# Setup:
#   1. Go to https://console.cloud.google.com/google/maps-apis
#   2. Enable: Places API (New)
#   3. Create a browser-restricted API key — restrict to your domain(s)
#   4. Copy the key below
#
# Cost: Free up to 10,000 Autocomplete requests/month (then ~$2.83/1k).
#       Requests are only made when the user types 2+ characters in the
#       destination field and are debounced to 250 ms.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Admin Portal ─────────────────────────────────────────────────────────────
# Firebase UID of the admin user who can access /admin and approve/reject campaigns.
# Find your UID in the Firebase Console → Authentication → Users.
# The same value must be set as the ADMIN_UID environment variable for the
# reviewCampaign Cloud Function (firebase functions:config:set admin.uid="YOUR_UID").
VITE_ADMIN_UID=your_firebase_uid_here
